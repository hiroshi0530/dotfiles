function gdt_fc {
  local base="${1:-origin/main}"
  local head="${2:-HEAD}"
  git diff "$base...$head"
}

function psa {
  ps aux | grep "$1"
}

function dcexec {
  docker-compose exec "$1" /bin/zsh
}

# file system
function mkcd {
  mkdir -p "$1" && cd "$1"
}

# convert snake_case to CamelCase
function snake_to_camel {
  perl -pe 's#(_|^)(.)#\u$2#g'
}

# convert CamelCase to snake_case
function camel_to_snake {
  perl -pe 's#([A-Z])#_\L$1#g' | perl -pe 's#^_##'
}

function hdate {
  local d
  d="$(date '+%Y-%m-%dT%H:%M:%S+09:00')"
  echo "date: $d"
}

function hlastdate {
  local d
  d="$(date '+%Y-%m-%dT%H:%M:%S+09:00')"
  echo "lastmod: $d"
}

function number24 {
  seq -w 24
}

function ca {
  conda activate "$1"
}

function cda {
  conda deactivate
}

function md_to_latex {
  pandoc -r markdown-auto_identifiers -w latex "$1.md" -o "$1.tex"
}

# ghq
function cdg {
  local dir
  dir="$(ghq list | fzf -1 +m)"
  if [[ -n "$dir" ]]; then
    cd "$(ghq root)/$dir"
  fi
}

# vim で開く
function vfzf {
  local file
  file="$(fzf-tmux -p)"
  [[ -n "$file" ]] && v "$file"
}

# 下の階層へ移動
function cdf {
  local dir
  dir="$(find "${1:-.}" -path '*/\.*' -prune -o -type d -print 2>/dev/null | fzf +m)" && cd "$dir"
}

# 単語を含むファイルの検索
function grepf {
  local keyword selected_file
  keyword="$1"

  if [[ -z "$keyword" ]]; then
    echo 'Usage: grepf <keyword>'
    return 1
  fi

  selected_file="$(grep -rl --color=never "$keyword" . | fzf --preview='cat {}' --height=40% --layout=reverse)"
  [[ -n "$selected_file" ]] && v "$selected_file"
}

# docker helper functions
function dst {
  local cname
  cname="$(docker ps -a --format 'table {{.Names}}\t{{.ID}}\t{{.Status}}' | sed 1d | fzf -1 +m | awk '{print $1}')"
  [[ -n "$cname" ]] && docker start "$cname"
}

function dsp {
  local cname
  cname="$(docker ps --format 'table {{.Names}}\t{{.ID}}\t{{.Status}}' | sed 1d | fzf -1 +m | awk '{print $1}')"
  [[ -n "$cname" ]] && docker stop "$cname"
}

function dlog {
  local cname
  cname="$(docker ps -a --format 'table {{.Names}}\t{{.ID}}\t{{.Status}}' | sed 1d | fzf -1 +m | awk '{print $1}')"
  [[ -n "$cname" ]] && docker logs -f "$cname"
}

function drc {
  local cid
  cid="$(docker ps -a --format 'table {{.Names}}\t{{.ID}}\t{{.Status}}' | sed 1d | fzf -1 +m | awk '{print $2}')"
  [[ -n "$cid" ]] && docker rm "$cid"
}

function dri {
  local image_id
  image_id="$(docker images --format 'table {{.Repository}}\t{{.Tag}}\t{{.ID}}' | sed 1d | fzf -1 +m | awk '{print $3}')"
  [[ -n "$image_id" ]] && docker rmi "$image_id"
}

function dexec {
  local cname
  cname="$(docker ps -a --format 'table {{.Names}}\t{{.ID}}\t{{.Status}}' | sed 1d | fzf -1 +m | awk '{print $1}')"
  if [[ -n "$cname" ]]; then
    docker exec -it "$cname" bash -c 'echo "set -o vi" >> /root/.bashrc && echo "alias ll=\"ls -alh --color\"" >> /root/.bashrc && exec bash'
  fi
}

function din {
  local container_id
  container_id="$(docker ps --format 'table {{.ID}}\t{{.Names}}\t{{.Image}}' | sed 1d | fzf -1 +m | awk '{print $1}')"
  [[ -n "$container_id" ]] && docker inspect "$container_id"
}

function dstats {
  local container_id
  container_id="$(docker ps --format 'table {{.ID}}\t{{.Names}}\t{{.Image}}' | sed 1d | fzf -1 +m | awk '{print $1}')"
  if [[ -n "$container_id" ]]; then
    docker stats "$container_id"
  else
    echo 'No container selected'
  fi
}

function dcpd {
  docker compose up -d "$1"
}

function dcp {
  docker compose up "$1"
}
