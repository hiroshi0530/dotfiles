# command helpers
function command_not_found_handler {
  echo "$SHELL: $1: command not found"
  return 127
}

# クリップボード上のパスにディレクトリ移動
function ccd {
  local dir
  dir="$(cat /dev/clipboard 2>/dev/null)"
  if [[ -d "$dir" ]]; then
    builtin cd "$dir"
  else
    builtin cd /desktop
  fi
}

# ANSIカラーコード表示
function ansi_color {
  local a b n
  for a in 3 4; do
    for b in 0 1 2 4 7; do
      for n in ${a}0 ${a}1 ${a}2 ${a}3 ${a}4 ${a}5 ${a}6 ${a}7; do
        echo -en "\e[${b};${n}m"
        echo -n "\e[${b};${n}m"
        echo -ne "\e[0m"
        echo -n '  '
      done
      echo
    done
    echo
  done
}

